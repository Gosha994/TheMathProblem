<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="CalcButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">3dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">22sp</item>
        <item name="android:backgroundTint">@color/btn_dark</item>
        <item name="android:fontFamily">sans-serif-light</item>
    </style>

    <style name="OpButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">3dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">22sp</item>
        <item name="android:backgroundTint">@color/btn_op</item>
        <item name="android:fontFamily">sans-serif-light</item>
    </style>

    <style name="MemButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">3dp</item>
        <item name="android:textColor">@color/memory_indicator</item>
        <item name="android:textSize">14sp</item>
        <item name="android:backgroundTint">@color/btn_mem</item>
        <item name="android:fontFamily">sans-serif-light</item>
    </style>
</resources>
