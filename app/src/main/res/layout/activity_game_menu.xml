<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a1a"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎮 Меню игр"
        android:textColor="#FFD700"
        android:textSize="28sp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvMenuStats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#AAAAFF"
        android:textSize="14sp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnSlotMachine"
        android:layout_width="240dp"
        android:layout_height="56dp"
        android:text="🎰 Слот-машина (100 💰)"
        android:textSize="14sp"
        android:textColor="#FFD700"
        android:background="@drawable/btn_dark"
        android:layout_margin="8dp"/>

    <Button
        android:id="@+id/btnPlatformer"
        android:layout_width="240dp"
        android:layout_height="56dp"
        android:text="🏃 Платформер"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_dark"
        android:layout_margin="8dp"/>

    <Button
        android:id="@+id/btnTetris"
        android:layout_width="240dp"
        android:layout_height="56dp"
        android:text="🧩 Тетрис"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_dark"
        android:layout_margin="8dp"/>

    <Button
        android:id="@+id/btnClose"
        android:layout_width="240dp"
        android:layout_height="56dp"
        android:text="✖ Закрыть"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_equals"
        android:layout_marginTop="24dp"/>

</LinearLayout>
